{
  "server": {
    "port": "8080",
    "trustedProxies": []
  },
  "database": {
    "driver": "sqlite",
    "url": "file:./data/dolgate_sync.db?_pragma=busy_timeout(5000)"
  },
  "auth": {
    "signingPrivateKeyPath": "./data/auth-signing-private.pem",
    "accessTokenTtlMinutes": 15,
    "refreshTokenIdleDays": 14,
    "offlineLeaseTtlHours": 72,
    "refreshRotationHandoffSeconds": 120,
    "rateLimit": {
      "login": {
        "limit": 10,
        "windowSeconds": 300
      },
      "signup": {
        "limit": 5,
        "windowSeconds": 900
      },
      "refresh": {
        "limit": 30,
        "windowSeconds": 300
      },
      "exchange": {
        "limit": 30,
        "windowSeconds": 300
      }
    },
    "local": {
      "enabled": true,
      "signupEnabled": true
    },
    "oidc": {
      "enabled": false,
      "displayName": "SSO",
      "issuerUrl": "",
      "clientId": "",
      "clientSecret": "",
      "redirectUrl": "https://ssh.doldolma.com/auth/oidc/callback",
      "scopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  }
}

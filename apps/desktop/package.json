{
  "name": "@keyterm/desktop",
  "version": "0.1.0",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,keytar",
    "postinstall": "npm run rebuild:native",
    "predev": "npm run rebuild:native",
    "prebuild": "npm run rebuild:native",
    "dev": "electron-forge start",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "test": "vitest run --config vite.renderer.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@keyterm/shared": "0.1.0",
    "better-sqlite3": "^11.8.1",
    "fuse.js": "^7.0.0",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
